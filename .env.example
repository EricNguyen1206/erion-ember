# Erion Ember v3 — Environment Configuration
# cp .env.example .env

# ─── Server ──────────────────────────────────────────────
HTTP_PORT=8080

# ─── Cache ───────────────────────────────────────────────
# Cosine similarity threshold for semantic cache hits (0.0 – 1.0)
CACHE_SIMILARITY_THRESHOLD=0.85

# Maximum number of cached entries (LRU eviction when exceeded)
CACHE_MAX_ELEMENTS=100000

# Default TTL in seconds (0 = no expiry)
CACHE_DEFAULT_TTL=3600

# ─── Embedding Worker Pool ────────────────────────────────
# Number of ONNX worker goroutines (0 = runtime.NumCPU())
EMBED_WORKERS=4

# Directory containing the ONNX model file (e.g. all-MiniLM-L6-v2)
# Leave empty to disable semantic similarity (exact-match only)
MODEL_DIR=
